# ============================================================
# OpenClaw AI Team - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM API Keys ---
# OpenAI (recommended, used by default)
OPENAI_API_KEY=sk-your-openai-api-key

# Groq (alternative, free tier has low token limits)
# GROQ_API_KEY=gsk_your-groq-api-key

# --- Slack (single app, shared by all agents) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# --- Bitbucket Configuration ---
BITBUCKET_WORKSPACE=your-workspace

EMMA_BITBUCKET_USERNAME=emma-ai-lead
EMMA_BITBUCKET_APP_PASSWORD=your-emma-app-password

MORGAN_BITBUCKET_USERNAME=morgan-ai-arch
MORGAN_BITBUCKET_APP_PASSWORD=your-morgan-app-password

SEAN_BITBUCKET_USERNAME=sean-ai-dev
SEAN_BITBUCKET_APP_PASSWORD=your-sean-app-password

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
