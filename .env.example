# ============================================================
# OpenClaw AI Team - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM API Keys ---
# OpenAI (recommended, used by default)
OPENAI_API_KEY=sk-your-openai-api-key

# Groq (alternative, free tier has low token limits)
# GROQ_API_KEY=gsk_your-groq-api-key

# --- Slack (separate app per agent) ---
EMMA_SLACK_BOT_TOKEN=xoxb-your-emma-bot-token
EMMA_SLACK_APP_TOKEN=xapp-your-emma-app-token

MORGAN_SLACK_BOT_TOKEN=xoxb-your-morgan-bot-token
MORGAN_SLACK_APP_TOKEN=xapp-your-morgan-app-token

SEAN_SLACK_BOT_TOKEN=xoxb-your-sean-bot-token
SEAN_SLACK_APP_TOKEN=xapp-your-sean-app-token

# --- Bitbucket Configuration ---
BITBUCKET_WORKSPACE=your-workspace

EMMA_BITBUCKET_USERNAME=your-emma-email@example.com
EMMA_BITBUCKET_APP_PASSWORD=your-emma-api-token

MORGAN_BITBUCKET_USERNAME=your-morgan-email@example.com
MORGAN_BITBUCKET_APP_PASSWORD=your-morgan-api-token

SEAN_BITBUCKET_USERNAME=your-sean-email@example.com
SEAN_BITBUCKET_APP_PASSWORD=your-sean-api-token

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
