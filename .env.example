# ============================================================
# OpenClaw AI Team - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Groq API (cloud LLM inference) ---
GROQ_API_KEY=gsk_your-groq-api-key

# --- Model Configuration ---
# Emma & Morgan: qwen3-32b (reasoning, 131K context)
# Sean: qwen-2.5-coder-32b (coding-optimized)
EMMA_MODEL=qwen3-32b
MORGAN_MODEL=qwen3-32b
SEAN_MODEL=qwen-2.5-coder-32b
FALLBACK_MODEL=qwen-2.5-coder-32b

# --- Slack Bot Tokens (Emma) ---
EMMA_SLACK_BOT_TOKEN=xoxb-your-emma-bot-token
EMMA_SLACK_APP_TOKEN=xapp-your-emma-app-token

# --- Slack Bot Tokens (Morgan) ---
MORGAN_SLACK_BOT_TOKEN=xoxb-your-morgan-bot-token
MORGAN_SLACK_APP_TOKEN=xapp-your-morgan-app-token

# --- Slack Bot Tokens (Sean) ---
SEAN_SLACK_BOT_TOKEN=xoxb-your-sean-bot-token
SEAN_SLACK_APP_TOKEN=xapp-your-sean-app-token

# --- Bitbucket Configuration ---
BITBUCKET_WORKSPACE=krixerx

EMMA_BITBUCKET_USERNAME=emma-ai-lead
EMMA_BITBUCKET_APP_PASSWORD=your-emma-app-password

MORGAN_BITBUCKET_USERNAME=morgan-ai-arch
MORGAN_BITBUCKET_APP_PASSWORD=your-morgan-app-password

SEAN_BITBUCKET_USERNAME=sean-ai-dev
SEAN_BITBUCKET_APP_PASSWORD=your-sean-app-password

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
